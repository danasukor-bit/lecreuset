, -50%);z-index:10}@media only screen and (max-width: 910px){#ltkpopup-overlay.ltkpopup-teaser-slider:before{max-width:439px;max-height:625px}}@media only screen and (max-width: 320px){#ltkpopup-overlay.ltkpopup-teaser-slider:before{max-width:309px;max-height:625px}}@keyframes slide-right{from{margin-left:100%}to{margin-left:0}}@keyframes slide-left{from{margin-left:0}to{margin-left:-100%}}#ltkpopup-content.ltkpopup-slide{animation:1s slide-right}@media only screen and (max-width: 910px){#ltkpopup-content.ltkpopup-confirm.ltkpopup-teaser-slider{max-height:none}}#ltkpopup-content.ltkpopup-teaser-slider{width:600px;background:transparent}@media only screen and (max-width: 910px){#ltkpopup-content.ltkpopup-teaser-slider{width:320px}}#ltkpopup-content.ltkpopup-teaser-slider #ltkpopup-content-step-1 .ltkpopup-button-container{max-width:330px;margin:0 auto 0}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content{position:relative;z-index:10}@media only screen and (max-width: 767px){#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-split-lr{max-width:450px}}@media only screen and (max-width: 320px){#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-split-lr{max-width:320px}}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form{overflow:hidden;max-width:100%;-webkit-box-flex:0 0 100%;-moz-box-flex:0 0 100%;-webkit-flex:0 0 100%;-ms-flex:0 0 100%;flex:0 0 100%;background:#ffffff;min-height:636px}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1{transition:margin 0.55s linear;padding-top:190px}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1 .ltkpopup-logo{margin-bottom:125px}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1.page-removed{margin-left:-400%}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-2{padding-top:115px;margin-left:300%;display:none}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-2.page-visible{transition:margin 1.05s linear;margin-left:300%;display:block}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-2.page-removed{margin-left:-400%;display:none}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-2.page-removed2{margin-left:-500%;display:none}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-3{padding-top:30px;margin-left:700%;display:none}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-3.page-visible{transition:margin 1.05s linear;margin-left:700%;display:block}#ltkpopup-content.ltkpopup-teaser-slider .ltkpopup-split-content .ltkpopup-contain-img{display:none}#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm.ltkpopup-confirm-step-3 #ltkpopup-content-step-2{padding-top:190px}#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm.ltkpopup-existing-sub .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1{padding-top:15px}@media only screen and (max-width: 767px){#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm.ltkpopup-existing-sub .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1{padding-top:70px}}#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm .ltkpopup-confirm-step-3{display:block}#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1{padding-top:85px}#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm .ltkpopup-split-content .ltkpopup-contain-form{background:#ffffff;padding:30px 15px 0}#ltkpopup-content.ltkpopup-teaser-slider.ltkpopup-confirm .ltkpopup-split-content .ltkpopup-contain-form#ltkpopup-content-step-1 .ltkpopup-logo{margin-bottom:15px}\n',confirmationHTML:'\t\t\t\t\t<!-- IMP-59234 -->\n\n<style>\n.containerbotao{max-width: 222px !important;margin: 15px 10px 0 !important;float: left !important; background-color: #FE5000 !important;}\n.botaolaranja{background-color: #FE5000 !important;}\n\n.botaolaranja:hover , .containerbotao:hover {background-color: white !important; color: #656565 !important;}\n\n\n containerbotao a, containerbotao a:link, containerbotao a:visited, containerbotao a:hover, containerbotao a:active {\n    text-decoration: none;}\n<\/style>\n\n \n\n\n\n<div id="ltkpopup-wrapper" class="confirm ltkpopup-no-scroll" name="version3-custom" role="dialog" aria-modal="true" aria-labelledby="ltkpopup-confirm-label" aria-describedby="ltkpopup-confirm-desc">\n\n\t<div id="ltkpopup-content" class="ltkpopup-confirm ltkpopup-split-lr ltkpopup-plain ltkpopup-img-included">\n\n\t\t\n\n\t\t\t<div class="ltkpopup-clearfix ltkpopup-split-content ">\n    \n    \n    <div class="ltkpopup-contain-img">\n\n        \n\t\t\t<img src="https://mediacdn.espssl.com/7895/Shared/BR/OnsiteContent/Popup/pop-up_exit_banner.jpeg" alt="" aria-hidden=true class="ltkpopup-img-fluid">\n\t\t\n\n    <\/div>\n\t\n\n    <div class="ltkpopup-contain-form">\n\n\t\t\n<img src="https://mediacdn.espssl.com/7895/Shared/BR/OnsiteContent/Popup/logo.jpg" class="ltkpopup-logo" alt="Le Creuset">\n\n\n        <div class="ltkpopup-form-control" id="ltkpopup-steps-wrap">\n\n\t\t\t\n            \n                <div id="ltkpopup-confirm-label">\n\t<h3>\n\t\t<span class="ltkpopup-line-1">Parabéns!<\/span>\n\t<\/h3>\n\n\t\n\n<\/div>\n\n<div id="ltkpopup-confirm-desc">\n\n\t\n\n\t\t\n\t\t\t\n\t\t\t<p>E-mail cadastrado com sucesso!<\/br> Você agora faz parte da nossa newsletter.<\/p>\n\t\t\t<p>Em breve, enviaremos novidades sobre lançamentos, ofertas exclusivas, eventos especiais e muito mais.<\/p>\n\t\t<p>Aproveite agora para conhecer nossos lançamentos e ofertas do momento:<\/p>\n\n    \n\n<\/div>\n                \n        <div class="ltkpopup-button-container containerbotao" >\n\t\t\t <a href="https://www.lecreuset.com.br/lancamentos/" style="padding: 0;" class="botaolaranja" >\n\t\t\t\t<button  type="button" class="ltkpopup-close botaolaranja" tabindex="0" role="button" aria-label="Comprar agora">ver Lançamentos<\/button>\n\t\t\t<\/a>\n\t\t<\/div>\n\t\t<div class="ltkpopup-button-container containerbotao" >\n\t\t\t<a href="https://www.lecreuset.com.br/ofertas-le-creuset/" style="padding: 0;" class="botaolaranja" >\n\t\t\t\t<button  type="button" class="ltkpopup-close botaolaranja" tabindex="0" role="button" aria-label="Comprar agora">ver ofertas<\/button>\n\t\t\t<\/a>\n\t\t<\/div>\n                \n                \n            \n            \n\n            \n\n        <\/div>\n\t\t\n\n    <\/div>\n    \n<\/div>\n\n\n\n\n\t\t\n\n\t\t<div class="ltkpopup-close-button" id="ltkpopup-close-x">\n    <button type="button" class="ltkpopup-close" tabindex="0" role="button" aria-labelledby="ltkpopup-close-title" aria-describedby="ltkpopup-close-desc">\n        \n\t\t\n\n\t\t<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 30 30">\n            <title id="ltkpopup-close-title">Close<\/title>\n            <desc id="ltkpopup-close-desc">Closes Web Dialog<\/desc>\n            <line x1="1" y1="1" x2="28" y2="28" />\n            <line x1="28" y1="1" x2="1" y2="28" />\n        <\/svg>\t\n\n\t\t\n\n    <\/button>\n<\/div>\n\n\t<\/div>\n\n<\/div>\n\n\n\n\n\n\n\n\t\n\n\n\n\n\n\n<script>\n\tsetTimeout(function(){\n\tdocument.getElementById(\'ltkpopup-close-x\').classList.add(\'ltk-close-show\');\n}, 2000);\n\ndocument.getElementById(\'ltkpopup-container\').addEventListener("click", function(e){\n    if (e.target == this) {\n        document.getElementById("ltkpopup-overlay").click();\n    }\n});\n\n\nvar ltkStep4Btns = document.querySelectorAll(".ltkpopup-step-4");\nvar ltkStep2Elems = document.querySelectorAll(\'.ltkpopup-confirm-step-2\');\nvar ltkStep3Elems = document.querySelectorAll(\'.ltkpopup-confirm-step-4\');\n\nfor (var i = 0; i < ltkStep4Btns.length; i++) {\n\tvar ltkStep4Btn = ltkStep4Btns[i];\n\t\n\tif ( ltkStep4Btn ) {\n\t\tltkStep4Btn.addEventListener(\'click\',function(e){\n\t\t\t//ltkStep2.classList.remove(\'page-visible\');\t\n\t\t\tdocument.getElementById(\'ltkpopup-steps-wrap\').classList.add(\'page-hidden\');\t\n\t\t\t// for (var i = 0; i < ltkStep2Elems.length; i++) {\n\t\t\t// \tvar ltkStep2 = ltkStep2Elems[i];\n\t\t\t// \tltkStep2.classList.remove(\'page-visible\');\t\n\t\t\t// }\n\n\t\t\tfor (var i = 0; i < ltkStep3Elems.length; i++) {\n\t\t\t\tvar ltkStep3 = ltkStep3Elems[i];\n\t\t\t\tltkStep3.classList.add(\'page-visible\');\t\n\t\t\t}\n\t\t\tdocument.getElementById(\'ltkpopup-content\').classList.add(\'ltkpopup-confirm-step-4\');\n\t\t});\n\t}\n\n}\n\nif (document.getElementById("ltkpopup-wrapper")) {\n    document.getElementById(\'ltkpopup-wrapper\').addEventListener(\'click\',function(e){\n        if( e.target == this ){\n            document.getElementById(\'ltkpopup-overlay\').click();\n        }\n    });\n}\n\nfunction getUrlParameter(name) {\n\tname = name.replace(/[\\[]/, \'\\\\[\').replace(/[\\]]/, \'\\\\]\');\n\tvar regex = new RegExp(\'[\\\\?&]\' + name + \'=([^&#]*)\');\n\tvar results = regex.exec(location.search);\n\treturn results === null ? \'\' : decodeURIComponent(results[1].replace(/\\+/g, \' \'));\n}\n\nfunction ltkGoToPage(pageNum) {\n\tvar visiblePage = document.querySelector(\'[data-ltkpage].page-visible\');\n\tvar pages = document.querySelectorAll(\'[data-ltkpage]\');\n\tif( pageNum == undefined ) {\n\t\tpageNum = Number(visiblePage.getAttribute(\'data-ltkpage\'))+1;\n\n\t}\n\tif( pageNum > pages.length ) {\n\t\tpageNum = 1;\n\t}\n\tif( visiblePage ) {\n\t\t// visiblePage.classList.remove(\'page-visible\');\n\t\tvar allPages = document.querySelectorAll(\'[data-ltkpage]\');\n\t\tfor (var i = 0; i < allPages.length; i++) {\n\t\t\tvar element = allPages[i];\n\t\t\telement.classList.remove(\'page-visible\');\n\t\t\t\n\t\t}\n\t\tdocument.querySelector(\'[data-ltkpage="\'+pageNum+\'"]\').classList.add(\'page-visible\');\n\t}\n\t\n\tvar urlParams =  new URL(window.location.href);\n\turlParams.searchParams.set(\'data-ltkpage\', pageNum);\n\twindow.history.pushState({}, \'\', urlParams.toString());\n}\n\nif( window.location.href.indexOf("data-ltkpage") > -1 ) {\n\tltkGoToPage(getUrlParameter(\'data-ltkpage\'));\n}\n\n\n// Check Input Validity\nfunction checkInputValidity(inputEl) {\n\tvar ltkErrorClass = "ltkinputnotvalid";\n\tvar ltkErrorMessage = document.querySelector("[data-ltk-error-for=\'" + inputEl.id + "\']");\n\tvar ltkLabel = document.querySelector("label[for=\'" + inputEl.id + "\']");\n\tif (ltkErrorMessage != undefined) {\n\t\tltkErrorMessage.innerText = "";\n\t\tinputEl.classList.remove(ltkErrorClass);\n\t\tif (ltkLabel != undefined) {\n\t\t\tltkLabel.classList.remove(ltkErrorClass);\n\t\t}\n\t}\n\tinputEl.checkValidity();\n\tif (!inputEl.validity.valid) {\n\t\tinputEl.classList.add(ltkErrorClass);\n\t\tif (ltkLabel != undefined) {\n\t\t\tltkLabel.classList.add(ltkErrorClass);\n\t\t}\n\t\tif (ltkErrorMessage != undefined) {\n\t\t\tltkErrorMessage.innerText = ltkErrorMessage.getAttribute("data-ltk-message");\n\t\t}\n\t\treturn false;\n\t}\n\treturn true;\n}\n\n\n\nvar ltkSubmitBtn = document.getElementById("ltkpopup-submit");\n\nif( \'entry\' == \'sms-before-email\' ) {\n\tltkSubmitBtn = document.getElementById("ltkpopup-mobile-submit");\n}\nif (ltkSubmitBtn != null) {\n\tltkSubmitBtn.addEventListener(\'click\', function () {\n\t\tvar e = jQuery("#ltkpopup-content :input");\n\t\tjQuery(e).each(function (e) {\n\t\t\tcheckInputValidity(this);\n\t\t\tif (jQuery(this).is(":invalid")) {\n\t\t\t\tthis.setAttribute("aria-describedby", this.id + "-error-message");\n\t\t\t} else {\n\t\t\t\tthis.removeAttribute("aria-describedby")\n\t\t\t}\n\t\t});\n\t\tsetTimeout(function () {\n\t\t\tif (document.querySelector(".ltkinputnotvalid") != null) {\n\t\t\t\tdocument.querySelector(".ltkinputnotvalid").focus();\n\t\t\t}\n\t\t}, 0);\n\t});\n}\njQuery(".ltkpopup-close").focus(function() {\n    jQuery(".ltkpopup-close").keypress(function(e) {\n        13 == e.which && jQuery("#ltkpopup-overlay, #ltkpopup-container").remove()\n    })\n});\n\ndocument.querySelectorAll(\'.ltkpopup-floating-label-container input, .ltkpopup-floating-label-container select\').forEach(function (input) {\n    input.addEventListener(\'blur\', removeFloat, false);\n    if (input.hasAttribute(\'data-inputmask\') || input.id === \'ltkpopup-datepicker\') {\n        input.addEventListener(\'focus\', addFloat, false);\n    } else {\n        input.addEventListener(\'click\', addFloat, false);\n        input.addEventListener(\'keydown\', addFloat, false);\n    }\n});\n\nfunction addFloat(event) {\n    event.target.closest(".ltkpopup-floating-label-container").classList.add(\'ltkpopup-floatLabel\');\n    const errorLabel = document.querySelector("[data-ltkpopup-error-for=\'" + event.target.id + "\']");\n    if (errorLabel) {\n        errorLabel.classList.add(\'ltkpopup-floatLabel\');\n    }\n}\n\nfunction removeFloat(event) {\n    if (event.target.value.length === 0 && !event.target.classList.contains("ltkpopup-datepicker")) {\n        event.target.closest(".ltkpopup-floating-label-container").classList.remove(\'ltkpopup-floatLabel\');\n        const errorLabel = document.querySelector("[data-ltkpopup-error-for=\'" + event.target.id + "\']");\n        if (errorLabel) {\n            errorLabel.classList.remove(\'ltkpopup-floatLabel\');\n        }\n    }\n}\tvar datepickerField = document.querySelector("#ltkpopup-datepicker");\nif (datepickerField != null) {\n\tvar jQueryUIcss = document.createElement("link");\n\tjQueryUIcss.href = "https://code.jquery.com/ui/1.12.1/themes/base/jquery-ui.css";\n\tjQueryUIcss.rel = "stylesheet";\n\tjQueryUIcss.addEventListener("load", function () {\n\t\tvar jQueryUI = document.createElement("script");\n\t